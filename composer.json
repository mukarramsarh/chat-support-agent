{
    "name": "support-ai/agent",
    "description": "Generic, production-grade AI support agent. PHP + shared-hosting friendly, embeddable via shortcode, RAG over PDF/DOCX/URL/text with a budget-aware evaluation loop.",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": ">=8.1",
        "ext-pdo": "*",
        "ext-curl": "*",
        "ext-json": "*",
        "ext-mbstring": "*",
        "smalot/pdfparser": "^2.7",
        "fivefilters/readability.php": "^3.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "SupportAI\\": "src/"
        },
        "files": [
            "src/Support/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "SupportAI\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true
    },
    "scripts": {
        "migrate": "php bin/console migrate",
        "test": "phpunit"
    }
}
