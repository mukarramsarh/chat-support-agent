# ─────────────────────────────────────────────────────────────
#  support-ai  ·  environment configuration
#  Copy to `.env` and fill in. Never commit `.env`.
# ─────────────────────────────────────────────────────────────

APP_ENV=production          # production | local
APP_DEBUG=false
APP_URL=https://your-domain.com
APP_KEY=                    # 32+ char random string, used to encrypt stored API keys
APP_TIMEZONE=UTC

# ── Database (MySQL / MariaDB) ──────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=support_ai
DB_USER=root
DB_PASS=pass
DB_CHARSET=utf8mb4

# ── Vector store ────────────────────────────────────────────
# auto = probe DB, prefer MySQL9 VECTOR, else Pinecone (if key), else PHP cosine
VECTOR_DRIVER=auto          # auto | mysql | pinecone | php
PINECONE_API_KEY=
PINECONE_INDEX_HOST=        # e.g. https://xxxx.svc.region.pinecone.io

# ── LLM providers (only the ones you use need keys) ─────────
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ── Model routing (sensible low-cost defaults) ──────────────
CHAT_PROVIDER=gemini                     # gemini | openai | anthropic
CHAT_MODEL=gemini-flash-latest           # resolved against provider model-list at runtime
UTILITY_MODEL=gemini-flash-lite-latest   # rerank / summarize / memory extraction
EMBEDDING_PROVIDER=openai                # openai | gemini
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# ── Budget guardrails ───────────────────────────────────────
MONTHLY_BUDGET_USD=2.00
MAX_TOKENS_PER_ANSWER=800
RETRIEVAL_TOP_K=20
RETRIEVAL_FINAL_K=5
RETRIEVAL_MIN_SCORE=0.20     # below this, decline instead of drafting (free gate)
ENABLE_ANSWER_CACHE=true
ENABLE_PROMPT_CACHE=true
