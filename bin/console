#!/usr/bin/env php
<?php

declare(strict_types=1);

/**
 * support-ai CLI. Usage:
 *   php bin/console install     # create schema + seed the single agent
 *   php bin/console migrate     # (re)apply database/schema.sql idempotently
 *   php bin/console cron        # drain the job queue once (call from crontab)
 *   php bin/console vector:info # show which vector store this host selects
 */

use SupportAI\Infrastructure\Database\Database;
use SupportAI\Infrastructure\Vector\VectorStoreFactory;
use SupportAI\Support\Container;

/** @var Container $c */
$c = require dirname(__DIR__) . '/bootstrap.php';

$command = $argv[1] ?? 'help';
$db = $c->get(Database::class);

switch ($command) {
    case 'install':
    case 'migrate':
        runSqlFile($db, dirname(__DIR__) . '/database/schema.sql');
        echo "✓ Schema applied.\n";
        if ($command === 'install') {
            runSqlFile($db, dirname(__DIR__) . '/database/seed.sql');
            echo "✓ Seed applied. Visit /admin to create the owner account.\n";
        }
        break;

    case 'vector:info':
        $store = $c->get(VectorStoreFactory::class)->make();
        echo "Server: " . $db->serverVersion() . "\n";
        echo "Native VECTOR supported: " . ($db->supportsNativeVector() ? 'yes' : 'no') . "\n";
        echo "Selected driver: " . $store->driver() . "\n";
        break;

    case 'cron':
        // 1a) Drain queued ingestion jobs (background path for large sources).
        $jobs = $c->get(SupportAI\Application\Ingestion\IngestionWorker::class)->process(10);
        echo "cron: ingestion jobs done {$jobs['done']}, failed {$jobs['failed']}.\n";
        // 1b) Refresh URL sources that are due for a recrawl.
        $r = $c->get(SupportAI\Application\Ingestion\RecrawlService::class)->refreshDue(5);
        echo "cron: recrawl checked {$r['checked']} (updated {$r['updated']}, unchanged {$r['unchanged']}, failed {$r['failed']}).\n";
        // 2) Long-term memory: summarise + extract facts from grown conversations.
        $mem = $c->get(SupportAI\Application\Chat\MemoryMaintenanceService::class)->process(5);
        echo "cron: memory processed {$mem['processed']} conversation(s), +{$mem['facts']} fact(s).\n";
        // 3) Storage-limitation: purge data past the retention window.
        $purged = $c->get(SupportAI\Application\Compliance\ComplianceService::class)->purge();
        echo "cron: retention purge removed {$purged} conversation(s).\n";
        break;

    default:
        echo "Commands: install | migrate | cron | vector:info\n";
}

/** Execute a .sql file statement-by-statement (handles multi-statement files). */
function runSqlFile(Database $db, string $path): void
{
    if (!is_file($path)) {
        fwrite(STDERR, "SQL file not found: {$path}\n");
        exit(1);
    }
    $sql = file_get_contents($path);
    // Strip line comments, then split on semicolons at line ends.
    $sql = preg_replace('/^\s*--.*$/m', '', $sql);
    foreach (array_filter(array_map('trim', explode(";\n", $sql . "\n"))) as $statement) {
        if ($statement === '') {
            continue;
        }
        $db->pdo()->exec($statement);
    }
}
